{
  "manifest_version": 3,
  "name": "Luck Editor",
  "short_name": "Luck Editor",
  "version": "5.0.0",
  "minimum_chrome_version": "120",
  "description": "A local-first cookie editor with strict validation, explicit permissions, safe import and export, and temporary snapshots.",
  "permissions": [
    "activeTab",
    "cookies",
    "storage"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Luck Editor",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
  },
  "incognito": "not_allowed",
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
